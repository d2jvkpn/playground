for d in "/opt/bin" "$HOME/apps/bin" "$HOME/.local/bin"; do
    if [ ! -d "$d" ]; then
        continue
    fi

    case ":${PATH}:" in
    *:"$d":*)
        ;;
    *)
        export PATH="$d:$PATH"
        ;;
    esac
fi

for d in $(ls -d $HOME/.local/*/bin/ $HOME/apps/*/bin/ 2>/dev/null); do
    d=${d%/}

    case ":${PATH}:" in
    *:"$d":*)
        ;;
    *)
        export PATH="$d:$PATH"
        ;;
    esac
done
