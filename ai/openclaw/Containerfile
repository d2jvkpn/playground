FROM local/pyjs:trixie

####
ARG http_proxy
ARG https_proxy
ARG no_proxy

ENV http_proxy=$http_proxy \
    https_proxy=$https_proxy \
    no_proxy=$no_proxy

ARG build_region
ARG openclaw_version=latest

####
USER root

COPY copy_files/scripts/. /opt/scripts/
RUN bash /opt/scripts/_install_tools.sh

####
USER appuser
WORKDIR /home/appuser

RUN if [ "$build_region" == "cn" ]; then \
        bash /opt/scripts/config_cn.sh pip; \
        bash /opt/scripts/config_cn.sh npm; \
    fi

# ENV OPENCLAW_HOME=/home/appuser/.openclaw
# ENV NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache
ENV NODE_COMPILE_CACHE=/home/appuser/.cache/openclaw/compile-cache \
    OPENCLAW_NO_RESPAWN=1

RUN npm install -g "openclaw@$openclaw_version" clawhub wscat && \
    mkdir -p ~/.openclaw ~/.agents && \
    rm -rf ~/.npm ~/.cache

# npm install -g @tobilu/qmd
# npm install -g @google/gemini-cli # gemini oauth
# curl -fsSL https://claude.ai/install.sh | bash
# curl -fsSL https://openclaw.ai/install.sh | bash

# clawhub install agent-browser
# npm install -g agent-browser
# agent-browser install

####
ENV https_proxy="" \
    http_proxy="" \
    no_proxy=""

RUN mkdir -p .openclaw .agents

VOLUME /home/appuser/.openclaw
VOLUME /home/appuser/.agents

WORKDIR /home/appuser/workspace

# webui: 18789, callback: 1455
EXPOSE 18789

ENTRYPOINT []
CMD ["openclaw", "gateway", "run", "--port=18789"]
