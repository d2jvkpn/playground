{
  "gateway": {
    "http": {
      "endpoints": {
        "responses": {
          "enabled": true,
          "maxBodyBytes": 20000000,
          "maxUrlParts": 8,
          "files": {
            "allowUrl": true,
            "urlAllowlist": [],
            "allowedMimes": [
              "text/plain",
              "text/markdown",
              "text/html",
              "text/csv",
              "application/json",
              "application/pdf"
            ],
            "maxBytes": 5242880,
            "maxChars": 200000,
            "maxRedirects": 3,
            "timeoutMs": 10000,
            "pdf": {
              "maxPages": 4,
              "maxPixels": 4000000,
              "minTextChars": 200
            }
          },
          "images": {
            "allowUrl": true,
            "urlAllowlist": [],
            "allowedMimes": [
              "image/jpeg",
              "image/png",
              "image/gif",
              "image/webp",
              "image/heic",
              "image/heif"
            ],
            "maxBytes": 10485760,
            "maxRedirects": 3,
            "timeoutMs": 10000
          }
        }
      }
    }
  }
}
