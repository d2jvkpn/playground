{
  "channels": {
    "feishu": {
      "enabled": true,
      "appId": "<APP_ID> example=cli_xxxxxxx, url=https://open.feishu.cn",
      "appSecret": "<APP_SECRET>",
      "connectionMode": "websocket",
      "domain": "feishu",
      "groupPolicy": "allowlist | disabled",
      "groupAllowFrom": [
        "<GROUP_ID> example=oc_xxxx, url=https://open.feishu.cn"
      ],
      "dmPolicy": "allowlist | dmPolicy",
      "allowFrom": [
        "<USER_ID_IN_APP> example=ou_xxxx, url=https://open.feishu.cn"
      ]
    }
  },

  "plugins": {
    "entries": {
      "feishu": {
        "enabled": true
      }
    }
  }
}
